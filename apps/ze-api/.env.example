# Copy to .env and fill in values before starting the server.

# ── ze-api shell ─────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
DATABASE_URL=postgresql://ze:ze@localhost:5432/ze
DATABASE_URL_SYNC=postgresql+psycopg2://ze:ze@localhost:5432/ze
AUTO_MIGRATE=false
ZE_API_KEY=change-me
CONFIRM_TIMEOUT_SECONDS=900

# ntfy push notifications (Phase 42)
# Required when using ntfy.sh — keep the topic non-guessable.
# Generate once: ze-$(openssl rand -hex 8)
NTFY_BASE_URL=https://ntfy.sh
NTFY_TOPIC=
NTFY_TOKEN=   # required for ntfy.sh; optional for self-hosted

# Browser sidecar (prospecting agent)
BROWSER_SERVICE_URL=http://ze-browser.internal:8080
BROWSER_TIMEOUT_SECONDS=20

# Dev — human-readable console logs (set automatically by Makefile dev targets)
LOG_DEV=false
# Dev — local log file (set automatically by Makefile dev targets; leave empty for production)
LOG_FILE=

# ── ze-google (Calendar + Gmail) ─────────────────────────────────────────────
# Run scripts/google_auth.py to obtain GOOGLE_REFRESH_TOKEN.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ── ze-calendar / core ───────────────────────────────────────────────────────
# Default timezone for calendar/reminder agents (override in config.yaml timezone:)
TIMEZONE=UTC

# ── ze-memory ──────────────────────────────────────────────────────────────────
# Disable nightly memory consolidation (default: enabled)
# CONSOLIDATION_ENABLED=false

# ── ze-automation ──────────────────────────────────────────────────────────────
# Disable workflow scheduler (default: enabled)
# SCHEDULER_ENABLED=false

# ── ze-prospecting ─────────────────────────────────────────────────────────────
# Limits when config.yaml prospecting block is absent
PROSPECTING_MAX_ITERATIONS=15
PROSPECTING_STALE_TIMEOUT_MINUTES=60

# ── ze-trading212 (Finance plugin) ─────────────────────────────────────────────
TRADING212_API_KEY=
TRADING212_DEMO=false
