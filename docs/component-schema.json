{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ze UI Primitives",
  "$defs": {
    "FormField": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "field_type": {
          "type": "string"
        },
        "placeholder": {
          "type": "string"
        },
        "options": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "help_text": {
          "type": "string"
        },
        "default_value": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "label"
      ]
    },
    "ConnectionEvidence": {
      "type": "object",
      "properties": {
        "label": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        },
        "date": {
          "type": "string"
        },
        "source": {
          "type": "string"
        }
      },
      "required": [
        "label",
        "kind"
      ]
    },
    "ConnectionItem": {
      "type": "object",
      "properties": {
        "summary": {
          "type": "string"
        },
        "narrative": {
          "type": "string"
        },
        "relation": {
          "type": "string"
        },
        "confidence": {
          "type": "number"
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": {
                "type": "string"
              },
              "kind": {
                "type": "string"
              },
              "date": {
                "type": "string"
              },
              "source": {
                "type": "string"
              }
            },
            "required": [
              "label",
              "kind"
            ]
          }
        }
      },
      "required": [
        "summary",
        "narrative",
        "relation",
        "confidence"
      ]
    },
    "Col": {
      "type": "object",
      "properties": {
        "children": {
          "type": "string"
        },
        "gap": {
          "type": "string"
        },
        "variant": {
          "type": "string"
        }
      },
      "required": [
        "children"
      ]
    },
    "Row": {
      "type": "object",
      "properties": {
        "children": {
          "type": "string"
        },
        "gap": {
          "type": "string"
        },
        "align": {
          "type": "string"
        }
      },
      "required": [
        "children"
      ]
    },
    "Text": {
      "type": "object",
      "properties": {
        "content": {
          "type": "string"
        },
        "style": {
          "type": "string"
        },
        "color": {
          "type": "string"
        }
      },
      "required": [
        "content"
      ]
    },
    "Badge": {
      "type": "object",
      "properties": {
        "label": {
          "type": "string"
        },
        "color": {
          "type": "string"
        }
      },
      "required": [
        "label"
      ]
    },
    "Divider": {
      "type": "object",
      "properties": {}
    },
    "Spacer": {
      "type": "object",
      "properties": {
        "size": {
          "type": "string"
        }
      }
    },
    "Button": {
      "type": "object",
      "properties": {
        "label": {
          "type": "string"
        },
        "action": {
          "type": "string"
        },
        "style": {
          "type": "string"
        }
      },
      "required": [
        "label",
        "action"
      ]
    },
    "ProgressBar": {
      "type": "object",
      "properties": {
        "value": {
          "type": "number"
        },
        "label": {
          "type": "string"
        }
      },
      "required": [
        "value"
      ]
    },
    "Table": {
      "type": "object",
      "properties": {
        "headers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rows": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "title": {
          "type": "string"
        },
        "caption": {
          "type": "string"
        }
      },
      "required": [
        "headers",
        "rows"
      ]
    },
    "Form": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "fields": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "label": {
                "type": "string"
              },
              "field_type": {
                "type": "string"
              },
              "placeholder": {
                "type": "string"
              },
              "options": {
                "type": "string"
              },
              "required": {
                "type": "boolean"
              },
              "help_text": {
                "type": "string"
              },
              "default_value": {
                "type": "string"
              }
            },
            "required": [
              "id",
              "label"
            ]
          }
        }
      },
      "required": [
        "id",
        "title",
        "fields"
      ]
    },
    "Connections": {
      "type": "object",
      "properties": {
        "connections": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "summary": {
                "type": "string"
              },
              "narrative": {
                "type": "string"
              },
              "relation": {
                "type": "string"
              },
              "confidence": {
                "type": "number"
              },
              "evidence": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "label": {
                      "type": "string"
                    },
                    "kind": {
                      "type": "string"
                    },
                    "date": {
                      "type": "string"
                    },
                    "source": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "label",
                    "kind"
                  ]
                }
              }
            },
            "required": [
              "summary",
              "narrative",
              "relation",
              "confidence"
            ]
          }
        },
        "title": {
          "type": "string"
        }
      },
      "required": [
        "connections"
      ]
    }
  },
  "oneOf": [
    {
      "$ref": "#/$defs/Col"
    },
    {
      "$ref": "#/$defs/Row"
    },
    {
      "$ref": "#/$defs/Text"
    },
    {
      "$ref": "#/$defs/Badge"
    },
    {
      "$ref": "#/$defs/Divider"
    },
    {
      "$ref": "#/$defs/Spacer"
    },
    {
      "$ref": "#/$defs/Button"
    },
    {
      "$ref": "#/$defs/ProgressBar"
    },
    {
      "$ref": "#/$defs/Table"
    },
    {
      "$ref": "#/$defs/Form"
    },
    {
      "$ref": "#/$defs/Connections"
    }
  ]
}